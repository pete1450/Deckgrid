{
  "name": "deckgrid",
  "version": "1.0.0",
  "description": "A virtual streamdeck for controlling OBS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.deckgrid.app",
    "productName": "Deckgrid",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "remote/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "electron-store": "^11.0.2",
    "obs-websocket-js": "^5.0.7",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}
